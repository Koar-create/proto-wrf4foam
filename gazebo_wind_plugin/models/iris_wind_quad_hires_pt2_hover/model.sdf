<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="iris_wind_quad_hires_pt2_hover">
    <static>false</static>

    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>

      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.029125</ixx>
          <iyy>0.029125</iyy>
          <izz>0.055225</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <velocity_decay>
        <!-- Enough damping for believable attitude; wind torque arms are modest. -->
        <angular>0.28</angular>
      </velocity_decay>

      <collision name="collision">
        <geometry>
          <box><size>4.7 4.7 1.1</size></box>
        </geometry>
        <surface>
          <contact>
            <collide_bitmask>0x01</collide_bitmask>
            <ode>
              <max_vel>0.5</max_vel>
              <min_depth>0.005</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>0.6</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <sensor name="crash_contact" type="contact">
        <update_rate>50</update_rate>
        <contact>
          <collision>collision</collision>
        </contact>
        <plugin name="contact_watcher" filename="libContactWatcherPlugin.so">
          <crash_threshold_n>20.0</crash_threshold_n>
          <publish_disable_topic>~/hover_pid/disable</publish_disable_topic>
          <log_every_n>50</log_every_n>
        </plugin>
      </sensor>

      <visual name="body_visual">
        <geometry>
          <mesh>
            <scale>10 10 10</scale>
            <uri>model://iris_wind_quad_hires_demo/meshes/iris.stl</uri>
          </mesh>
        </geometry>
        <material>
          <script>
            <name>Gazebo/DarkGrey</name>
            <uri>file://media/materials/scripts/gazebo.material</uri>
          </script>
        </material>
      </visual>

    </link>

    <!-- Each rotor is its own link (no collision) connected to base_link via a
         revolute joint about Z. RotorSpinPlugin drives them via the ODE joint
         motor (SetParam fmax / vel) so the meshes visibly spin.
         Negligible inertia keeps reaction torques on base_link bounded. -->
    <link name="prop_0">
      <pose>1.3 -2.2 0.23 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>1.0e-5</ixx>
          <iyy>1.0e-5</iyy>
          <izz>2.0e-5</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="prop_0_visual">
        <geometry>
          <mesh>
            <scale>10 10 10</scale>
            <uri>model://iris_wind_quad_hires_demo/meshes/iris_prop_ccw.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name="prop_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>prop_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.0001</damping></dynamics>
      </axis>
    </joint>

    <link name="prop_1">
      <pose>-1.3 2.0 0.23 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>1.0e-5</ixx>
          <iyy>1.0e-5</iyy>
          <izz>2.0e-5</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="prop_1_visual">
        <geometry>
          <mesh>
            <scale>10 10 10</scale>
            <uri>model://iris_wind_quad_hires_demo/meshes/iris_prop_ccw.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name="prop_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>prop_1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.0001</damping></dynamics>
      </axis>
    </joint>

    <link name="prop_2">
      <pose>1.3 2.2 0.23 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>1.0e-5</ixx>
          <iyy>1.0e-5</iyy>
          <izz>2.0e-5</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="prop_2_visual">
        <geometry>
          <mesh>
            <scale>10 10 10</scale>
            <uri>model://iris_wind_quad_hires_demo/meshes/iris_prop_cw.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name="prop_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>prop_2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.0001</damping></dynamics>
      </axis>
    </joint>

    <link name="prop_3">
      <pose>-1.3 -2.0 0.23 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>1.0e-5</ixx>
          <iyy>1.0e-5</iyy>
          <izz>2.0e-5</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="prop_3_visual">
        <geometry>
          <mesh>
            <scale>10 10 10</scale>
            <uri>model://iris_wind_quad_hires_demo/meshes/iris_prop_cw.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name="prop_3_joint" type="revolute">
      <parent>base_link</parent>
      <child>prop_3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.0001</damping></dynamics>
      </axis>
    </joint>

    <plugin name="wind_field" filename="libWindFieldPlugin.so">
      <lut_json>/home/jeezen/wrf_openfoam_coupling_cache/wind_lut/20250903_1400_hires/wind_lut.json</lut_json>
      <lut_vti>/home/jeezen/wrf_openfoam_coupling_cache/wind_lut/20250903_1400_hires/wind_lut.vti</lut_vti>
      <link_name>base_link</link_name>
      <rho>1.225</rho>
      <C_D>1.2</C_D>
      <!-- Modest drag: readable buffeting without ±120° snap rolls. -->
      <area>0.14</area>
      <world_to_lut_offset_x>0</world_to_lut_offset_x>
      <world_to_lut_offset_y>0</world_to_lut_offset_y>
      <world_to_lut_offset_z>0</world_to_lut_offset_z>
      <log_every_n>250</log_every_n>
      <hotspot_x>1470</hotspot_x>
      <hotspot_y>1350</hotspot_y>
      <hotspot_z>80</hotspot_z>
      <enable_wind_torque>true</enable_wind_torque>
      <wind_torque_arm_z>0.14</wind_torque_arm_z>
      <wind_torque_arm_x>0.025</wind_torque_arm_x>
    </plugin>

    <!-- Same hull-offset loop as pt1 + softer barrier so corners follow the façade, not a distant box. -->
    <plugin name="inspection_path" filename="libInspectionPathControllerPlugin.so">
      <link_name>base_link</link_name>
      <arrival_radius>3.5</arrival_radius>
      <loop>true</loop>
      <waypoint x="1471.00" y="1309.00" z="80"/>
      <waypoint x="1461.75" y="1317.68" z="80"/>
      <waypoint x="1452.37" y="1321.41" z="80"/>
      <waypoint x="1445.01" y="1329.57" z="80"/>
      <waypoint x="1437.65" y="1337.74" z="80"/>
      <waypoint x="1430.29" y="1345.91" z="80"/>
      <waypoint x="1431.10" y="1356.77" z="80"/>
      <waypoint x="1436.43" y="1363.75" z="80"/>
      <waypoint x="1446.28" y="1366.86" z="80"/>
      <waypoint x="1456.13" y="1369.96" z="80"/>
      <waypoint x="1465.56" y="1368.57" z="80"/>
      <waypoint x="1474.59" y="1362.66" z="80"/>
      <waypoint x="1483.62" y="1356.76" z="80"/>
      <waypoint x="1492.65" y="1350.86" z="80"/>
      <waypoint x="1501.68" y="1344.96" z="80"/>
      <waypoint x="1507.92" y="1334.93" z="80"/>
      <waypoint x="1506.73" y="1326.32" z="80"/>
      <waypoint x="1498.11" y="1319.14" z="80"/>
      <waypoint x="1489.49" y="1311.96" z="80"/>
      <waypoint x="1480.50" y="1310.23" z="80"/>
      <waypoint x="1475.81" y="1312.10" z="80"/>
      <enable_xy>true</enable_xy>
      <kp>5.2</kp>
      <ki>0.07</ki>
      <kd>3.2</kd>
      <kp_z>4.2</kp_z>
      <ki_z>0.05</ki_z>
      <kd_z>2.6</kd_z>
      <log_every_n>250</log_every_n>
      <enable_attitude_recovery>true</enable_attitude_recovery>
      <attitude_kp>4.5</attitude_kp>
      <gravity_compensation>true</gravity_compensation>
      <drift_after_seconds>-1</drift_after_seconds>
      <enable_barrier_avoidance>true</enable_barrier_avoidance>
      <building_min_x>1436</building_min_x>
      <building_max_x>1506</building_max_x>
      <building_min_y>1314</building_min_y>
      <building_max_y>1366</building_max_y>
      <safety_margin>5.0</safety_margin>
      <barrier_gain>105</barrier_gain>
      <barrier_vel_gain>32</barrier_vel_gain>
      <disable_topic>~/hover_pid/disable</disable_topic>
      <crash_zero_thrust>false</crash_zero_thrust>
    </plugin>

    <!-- Visible rotor spin (no aerodynamic effect; HoverPid + WindField still drive the body).
         Signs alternate so CCW (props 0,1) and CW (props 2,3) reaction torques cancel on base_link. -->
    <plugin name="rotor_spin" filename="libRotorSpinPlugin.so">
      <rotor><joint>prop_0_joint</joint><rate>80</rate></rotor>
      <rotor><joint>prop_1_joint</joint><rate>80</rate></rotor>
      <rotor><joint>prop_2_joint</joint><rate>-80</rate></rotor>
      <rotor><joint>prop_3_joint</joint><rate>-80</rate></rotor>
      <max_torque>0.5</max_torque>
      <spin_up_tau>1.5</spin_up_tau>
      <spin_down_tau>1.0</spin_down_tau>
      <disable_topic>~/hover_pid/disable</disable_topic>
    </plugin>

    <plugin name="trail_marker" filename="libTrailMarkerPlugin.so">
      <link_name>base_link</link_name>
      <sample_period>0.75</sample_period>
      <marker_radius>0.3</marker_radius>
      <max_points>60</max_points>
      <color_r>1.0</color_r>
      <color_g>0.3</color_g>
      <color_b>0.1</color_b>
      <color_a>0.55</color_a>
    </plugin>
  </model>
</sdf>
